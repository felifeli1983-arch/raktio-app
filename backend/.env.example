# Raktio Backend — Environment Variables

# --- App ---
APP_ENV=development
DEBUG=true

# --- Anthropic (Claude Sonnet) — PLANNING + REPORT routes ---
ANTHROPIC_API_KEY=sk-ant-...

# --- DeepSeek — RUNTIME route ---
DEEPSEEK_API_KEY=...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Supabase ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_ANON_KEY=...

# --- Redis (job queue) ---
REDIS_URL=redis://localhost:6379

# --- Storage ---
STORAGE_PROVIDER=supabase
STORAGE_BUCKET_SOURCES=raktio-sources
STORAGE_BUCKET_EXPORTS=raktio-exports

# --- OASIS runtime ---
OASIS_PATH=../oasis-main
OASIS_RUN_WORKSPACE=/tmp/raktio-runs

# --- Model routing overrides (optional — defaults in config.py) ---
# MODEL_PLANNING=claude-sonnet-4-6
# MODEL_RUNTIME=deepseek-chat
# MODEL_REPORT=claude-sonnet-4-6
